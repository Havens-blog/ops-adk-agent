# LLM 配置（百炼 Coding Plan）
OPENAI_API_KEY=sk-sp-xxx
OPENAI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
OPENAI_MODEL=qwen3.5-plus

# 阿里云百炼 MCP API Key（每个账号独立的百炼 API Key）
DASHSCOPE_API_KEY_OPENCLAW=sk-xxx
DASHSCOPE_API_KEY_PRODUCTION=sk-xxx

# 阿里云 AccessKey（用于费用/退订/快照操作，需要 BSS + ECS 权限）
# openclaw 账号
ALIYUN_AK_OPENCLAW=你的AccessKeyId
ALIYUN_SK_OPENCLAW=你的AccessKeySecret
# 生产账号
ALIYUN_AK_PRODUCTION=你的AccessKeyId
ALIYUN_SK_PRODUCTION=你的AccessKeySecret

# ADK Server
ADK_PORT=8080
